# Ranunculus Blitz Tracker — Environment Configuration

# SQLite database path (Railway: use /data/blitz.db with persistent volume)
BLITZ_DB_PATH=blitz.db

# iNaturalist place ID (6857 = United Kingdom)
BLITZ_PLACE_ID=6857

# Seconds between diff cycles (default: 90)
BLITZ_DIFF_INTERVAL=90

# Auto-snapshot on startup (useful for pre-warming before the event)
BLITZ_AUTO_SNAPSHOT=false

# Target species — JSON array of {name, common, color}
# Default: three UK buttercup species if not set
BLITZ_SPECIES='[{"name": "Ranunculus repens", "common": "Creeping Buttercup", "color": "#d4a843"}, {"name": "Ranunculus acris", "common": "Meadow Buttercup", "color": "#4a7c3f"}, {"name": "Ranunculus bulbosus", "common": "Bulbous Buttercup", "color": "#c46a2b"}]'

# Teams configuration — JSON array
# Each team has a name, color (hex), and list of iNaturalist usernames
BLITZ_TEAMS='[{"name": "Team Buttercup", "color": "#d4a843", "members": ["alice", "bob"]}, {"name": "Team Meadow", "color": "#4a7c3f", "members": ["charlie", "diana"]}]'
